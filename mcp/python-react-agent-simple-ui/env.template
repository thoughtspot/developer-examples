# ── v2: Claude backend (claude_agent_mcp_server_v2.py) ──────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── v1: Azure OpenAI backend (agent.py) ─────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1
AZURE_OPENAI_KEY=your_azure_openai_key_here

# ── ThoughtSpot credentials (used by both + React client) ───────────
# VITE_ prefix exposes these to the browser via Vite's import.meta.env
VITE_TS_HOST=your-instance.thoughtspot.cloud
VITE_TS_AUTH_TOKEN=your_thoughtspot_bearer_token

# WARNING: Using a static bearer token (VITE_TS_AUTH_TOKEN) is for development
# and demo purposes only. Do NOT use this approach in production. For production
# deployments, implement the full Trusted Authentication flow where your backend
# securely generates short-lived tokens on behalf of each user.
# See: https://developers.thoughtspot.com/docs/trusted-auth
